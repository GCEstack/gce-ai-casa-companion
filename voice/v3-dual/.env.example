# IMPORTANT: Replace all placeholder values before use. Never commit real secrets.
# Casa Voice V3 — Environment Template
# Copy this file to .env and fill in your real keys.

# Comma-separated list of allowed CORS origins (no trailing slashes).
# Add your Vercel deployment URLs here; localhost entries are safe for development.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Recommended: Groq for STT + LLM, OpenRouter for TTS (no OpenAI key needed)
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Even faster TTS: add an OpenAI key for direct TTS (optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Simple fallback: OpenRouter handles STT, LLM, and TTS
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Provider model overrides
# GROQ_LLM_MODEL=llama-3.3-70b-versatile
# GROQ_STT_MODEL=whisper-large-v3-turbo
# GROQ_STT_TEMPERATURE=0
# GROQ_STT_RESPONSE_FORMAT=verbose_json   # verbose_json | json
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=nova
# OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_STT_MODEL=openai/whisper-1
# OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview

# Optional: Native audio (Quick Chat mode) — audio -> audio in one OpenRouter call.
# Set NATIVE_AUDIO_ENABLED=0 to disable. Model must be an OpenRouter native-audio model.
# NATIVE_AUDIO_ENABLED=1
# OPENROUTER_NATIVE_AUDIO_MODEL=openai/gpt-audio-mini
# NATIVE_AUDIO_VOICE=alloy

# Optional: TTS cache. Repeated phrases (greetings, trigger replies, story segments)
# are stored as PCM files and played instantly on the next use.
# TTS_CACHE_ENABLED=1
# TTS_CACHE_DIR=tts_cache

# Optional: Sentence-level LLM->TTS streaming. Starts speaking the first sentence
# while the LLM is still generating the rest. Enabled by default; set to 0 to disable.
# STREAMING_TTS_ENABLED=1

# Optional: OpenRouter provider routing: price | throughput | latency
# OPENROUTER_PROVIDER_SORT=latency

# Optional: Supabase persistence
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_service_role_or_anon_key

# Optional: VAD tuning (defaults shown)
# VAD_ENERGY_THRESHOLD=0.003
# VAD_PEAK_THRESHOLD=0.015

# Optional: Response-speed tuning (defaults shown)
# WAKE_MAX_SECONDS=1.5
# WAKE_SILENCE_MS=200
# COMMAND_SILENCE_MS=400
# COMMAND_MAX_SECONDS=10.0

# Optional: Wake-word engine
# WAKE_WORD_KEYWORDS=porcupine          # comma-separated Porcupine built-in keywords
# WAKE_WORD_PATHS=wakewords/casa.ppn    # comma-separated paths to custom .ppn files
# WAKE_WORD_SENSITIVITIES=0.5           # comma-separated, 0.0-1.0
# WAKE_WORD_DISABLED=0                  # set to 1 to fall back to STT wake detection
