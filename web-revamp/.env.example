# IMPORTANT: Replace all placeholder values before use. Never commit real secrets.
# Vite revamp frontend env vars
# These are exposed to the browser — do NOT put server-only secrets here.

# Voice backend (v3-dual) — used by the PCM WebSocket voice pipeline.
VITE_VOICE_SERVER_URL=wss://casa-voice-agent.fly.dev
VITE_VOICE_SERVER_API_KEY=your_voice_server_api_key_here

# Phone-as-parent-mic pairing URLs.
VITE_BACKEND_HTTP_URL=https://casa-voice-agent.fly.dev
# Use whichever Fly.io mobile PWA deployment the kid is on.
VITE_PARENT_JOIN_URL=https://casa-web-mobile-liam.fly.dev/pair

# Legacy browser-only pipeline keys (no longer used by web-revamp).
# Kept here temporarily for any external scripts that still reference them.
VITE_OPENAI_API_KEY=
VITE_DEEPGRAM_API_KEY=

# ⚠️  ROTATE REQUIRED: The previous ElevenLabs key was committed to Git history and is compromised.
# 1. Go to https://elevenlabs.io → Profile → API Keys → delete the old key → create a new one.
# 2. Replace PASTE_YOUR_NEW_ELEVENLABS_KEY_HERE below with the new key.
# 3. Set the same key in your Vercel project environment variables (for apps/landing and web-revamp).
# 4. Never commit this file with a real key value.
VITE_ELEVENLABS_API_KEY=PASTE_YOUR_NEW_ELEVENLABS_KEY_HERE
