{
  "expo": {
    "name": "CasaCompanion",
    "slug": "casa-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.casacompanion.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Casa Companion needs microphone access so your child can talk to their AI companion. Audio is only used for real-time conversation and is never stored.",
        "UIBackgroundModes": ["audio", "processing"],
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "android": {
      "package": "com.casacompanion.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE"
      ]
    }
  }
}
