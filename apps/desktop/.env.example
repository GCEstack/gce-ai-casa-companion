# IMPORTANT: Replace all placeholder values before use. Never commit real secrets.
# Casa Companion Desktop — environment variables
#
# Copy this file to .env.local (or set vars in your hosting dashboard).
# Never commit real .env files.

# Backend API URL used by the voice agent.
# Local dev: http://localhost:8080
# Production: https://casa-voice-agent.fly.dev
NEXT_PUBLIC_API_URL=https://casa-voice-agent.fly.dev

# Optional: Sentry error monitoring.
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
