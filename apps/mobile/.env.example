# IMPORTANT: Replace all placeholder values before use. Never commit real secrets.
# Casa Companion Mobile PWA — environment variables
#
# Copy this file to .env.local (or set vars in your hosting dashboard).
# Never commit real .env files.

# WebSocket URL of the voice/v3-dual backend.
# Local dev: ws://localhost:8080
# Production: wss://casa-voice-agent.fly.dev/ws/voice
VITE_VOICE_SERVER_URL=wss://casa-voice-agent.fly.dev/ws/voice

# API key the backend expects on the WebSocket query string (?token=...).
# Copy the real value from your master secrets file (voice/v3-dual/.env).
VITE_VOICE_SERVER_API_KEY=your_api_key_here

# Sentry error monitoring (optional).
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
# VITE_APP_VERSION=0.0.0
# VITE_VERCEL_ENV=development

# Sentry release-upload (build-time only; optional).
# These are used by vite.config.ts when sentryVitePlugin is enabled.
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=your_sentry_project

# Legacy browser-only voice pipeline keys (not used by useV3VoiceChat).
# VITE_OPENAI_API_KEY=sk-...
# VITE_DEEPGRAM_API_KEY=...
# VITE_GROQ_API_KEY=gsk_...

# Personalization (per-child builds).
# VITE_USER_NAME=Liam
# VITE_ENABLED_CHARACTERS=tartaruga,corvo,veloce,jack
# VITE_FEATURED_CHARACTER=tartaruga
